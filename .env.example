# ============================================
# AutoCut 环境变量模板
# 复制此文件为 .env 并填入实际值
# ============================================

# --- 数据库 ---
DATABASE_URL=sqlite:///./autocut.db

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","https://autocut.allinai.asia"]

# --- 文件上传 ---
UPLOAD_DIR=./uploads

# --- 17.1 业务配置 ---
FREE_QUOTA_INITIAL=3
PRICE_PER_VIDEO_CENTS=990
PRICE_MONTHLY_CENTS=9900
PRICE_YEARLY_CENTS=79900
MONTHLY_QUOTA=30
YEARLY_QUOTA=400
OVERAGE_PRICE_CENTS=690
PRICE_UNLIMITED_YEARLY_CENTS=149900
UNLIMITED_DAILY_LIMIT=10
VIDEO_RETENTION_HOURS=24
HISTORY_PAGE_SIZE=20

# --- 17.2 处理引擎配置 ---
MAX_FILE_SIZE_MB=500
MAX_TOTAL_DURATION_MIN=30
SUPPORTED_FORMATS=["mp4","mov","webm"]
MAX_RESOLUTION=1080p
FILLER_WORDS=["嗯","啊","那个","就是","然后"]
LONG_PAUSE_THRESHOLD_MS=1500
PAUSE_SHORTEN_TARGET_MS=500
MAX_EFFECTS_PER_MINUTE=3
BGM_DEFAULT_VOLUME=0.15
CROSSFADE_MS=50
WHISPER_LOW_CONFIDENCE_THRESHOLD=0.6
WHISPER_LOW_CONFIDENCE_WARN_RATIO=0.3

# --- 17.3 系统配置 ---
PROCESSING_TIMEOUT_MIN=15
RENDER_MAX_RETRY=1
MAX_CONCURRENT_TASKS=3
MAX_QUEUED_TASKS=20
LOGIN_CODE_EXPIRE_SEC=300
LOGIN_CODE_COOLDOWN_SEC=60
LOGIN_MAX_FAIL_ATTEMPTS=3
LOGIN_LOCKOUT_MIN=5
LLM_PROVIDER=claude
LLM_MODEL=claude-haiku
LLM_TIMEOUT_SEC=30
WHISPER_MODEL=large-v3
DEVICE_FINGERPRINT_MAX_ACCOUNTS=2
IP_SMS_HOURLY_LIMIT=10
PHONE_SMS_DAILY_LIMIT=5
CONTENT_MODERATION_PROVIDER=aliyun

# --- 17.4 文案配置 ---
HOMEPAGE_TITLE=口播视频，AI 一键出片
HOMEPAGE_SUBTITLE=上传素材 → AI 去口误、加字幕 → 几分钟出成品，每处修改可逐条审核
SATISFACTION_ENABLED=true
DEMO_ASSET_TYPE=static_image

# --- 外部服务 API Keys (按需填入) ---
# OPENAI_API_KEY=sk-...
# ALIYUN_SMS_ACCESS_KEY=
# ALIYUN_SMS_ACCESS_SECRET=
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_API_KEY=
