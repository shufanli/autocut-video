# AutoCut Video - Production Environment Variables
# Copy to /www/wwwroot/autocut-video/backend/.env

# --- JWT (CHANGE THIS in production!) ---
JWT_SECRET=autocut-prod-change-me-to-a-real-secret-key-2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=72

# --- Database ---
DATABASE_URL=sqlite:///./autocut.db

# --- CORS ---
CORS_ORIGINS=["https://autocut.allinai.asia","http://autocut.allinai.asia"]

# --- Upload storage ---
UPLOAD_DIR=./uploads

# --- OpenAI / Whisper API (optional, uses mock if empty) ---
OPENAI_API_KEY=
